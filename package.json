{
  "name": "@gyldlab/create-next",
  "version": "0.2.1",
  "license": "MIT",
  "description": "Built on a foundation of SOVEREIGN ALCHEMY — transforming vision into production-ready Next.js applications through curated templates and add-ons.",
  "author": {
    "name": "GYLDLAB",
    "email": "dev@gyldlab.com",
    "url": "https://gyldlab.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gyldlab/next-app.git"
  },
  "homepage": "https://github.com/gyldlab/next-app#readme",
  "bugs": {
    "url": "https://github.com/gyldlab/next-app/issues"
  },
  "keywords": [
    "nextjs",
    "next",
    "cli",
    "create",
    "scaffold",
    "template",
    "starter",
    "gyldlab",
    "shadcn",
    "elysia",
    "gsap",
    "lenis",
    "bun"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "create-next": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "docs/ANIMATION_GUIDE.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "bun test",
    "smoke:gsap-lenis": "bun ./scripts/smoke-gsap-lenis.ts",
    "smoke:shadcn": "bun ./scripts/smoke-shadcn.ts",
    "smoke:elysia": "bun ./scripts/smoke-elysia.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "asciify-image": "^0.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "svg2img": "^1.0.0-beta.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
